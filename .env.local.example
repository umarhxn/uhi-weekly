# ─────────────────────────────────────────────
# UHI Weekly — Environment Variables
# ─────────────────────────────────────────────
# 1. Go to https://resend.com → sign up free
# 2. Create an API key under "API Keys"
# 3. Paste it below
# 4. Replace the FROM address with your verified domain/email
#    (use onboarding@resend.dev for testing before you verify a domain)

RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# The "from" address shown to subscribers
RESEND_FROM=UHI Weekly <newsletter@yourdomain.com>

# Admin password to access the /admin panel
ADMIN_PASSWORD=changeme123

# Your site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
